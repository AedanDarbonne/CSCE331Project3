<html>
    <head>
        <title>Checkout</title>
        <link rel="stylesheet" href="/customer/customer.css">
    </head>
    <body>
    <%- include('../partials/navigation-customer') %>

    <main class="content-wrapper">
        <h1 class="page-title">Checkout</h1>

        <div class="checkout-form">
            <label>Name on Card</label>
            <input type="text" placeholder="John Doe">

            <label>Card Number</label>
            <input type="text" placeholder="1234 5678 9012 3456">

            <div class="row-2">
                <div>
                    <label>Expiration</label>
                    <input type="text" placeholder="MM/YY">
                </div>
                <div>
                    <label>CVV</label>
                    <input type="text" placeholder="123">
                </div>
            </div>

            <label>Email</label>
            <input type="email" placeholder="you@email.com">

            <button onclick="placeOrder()">Place Order</button>
        </div>
    </main>

    <script>
        async function placeOrder() {
            const cart = JSON.parse(localStorage.getItem('customer-cart') || '[]');
            if (cart.length === 0) {
                alert('Cart is empty');
                return;
            }

            const response = await fetch('/api/customer-checkout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ items: cart })
            });

            if (response.ok) {
                localStorage.setItem('customer-cart', '[]');
                window.location.href = '/customer/order-confirmation';
            }
        }
    </script>
    </body>
</html>
